# Copy to .env and adjust. Never commit the real .env.
NODE_ENV=development
# 4100 for local dev (4000 is commonly taken by other local stacks).
PORT=4100

# For local dev against the Dockerised infra, use the remapped host ports
# (compose maps mongo->27018, redis->6380 to avoid clashes with other stacks).
MONGO_URI=mongodb://localhost:27018/bookmyseat
REDIS_URL=redis://localhost:6380

JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Seconds a seat stays HELD before auto-release.
HOLD_TTL_SECONDS=300

LOG_LEVEL=info
